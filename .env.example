# Port for the log viewer
PORT=3102

# Maximum number of lines to load initially
MAX_LINES=500

# Auto-refresh poll interval in ms (0 to disable)
POLL_INTERVAL=2000

# Log sources configuration (JSON array)
# Two source types supported:
#   File:   { "name": "Display Name", "path": "/logs/syslog" }
#   Docker: { "name": "Display Name", "container": "container-name" }
LOG_SOURCES=[{"name":"Syslog","path":"/logs/syslog"},{"name":"My App","container":"my-app-container"}]
